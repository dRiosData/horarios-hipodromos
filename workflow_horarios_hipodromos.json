            "index": 0
          }
        ]
      ]
    },
    "Generar Tabla HTML": {
      "main": [
        [
          {
            "node": "Enviar Mail Horarios",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
